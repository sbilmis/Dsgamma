          RowBox[{"\"current status\"", "\[Rule]", 
            "\"AA is explicit; local BB and AB OPEs are not yet complete\""}]}\
], "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"f1ModelSquared", "=", 
        RowBox[{RowBox[{SuperscriptBox[RowBox[{"Sin", "[", "theta", "]"}], 
             "2"], " ", SuperscriptBox["fA", "2"]}], "+", 
