  Cell["Colangelo-style final OPE assembly", "Subsection"], 
  Cell["The paper-ready formula is assembled from named OPE components. The \
axial-current entries reproduce the implemented Colangelo sum rule. The \
tensor-current component slots remain symbolic until their independent \
spectral and condensate reductions are complete.", "Text"], 
  Cell[BoxData[RowBox[
     {RowBox[{RowBox[{"kallenLambda", "[", RowBox[{"shat_", ",", 
            "mass1Squared_", ",", "mass2Squared_"}], "]"}], ":=", 
        RowBox[{SuperscriptBox["shat", "2"], "+", SuperscriptBox[
           "mass1Squared", "2"], "+", SuperscriptBox["mass2Squared", "2"], 
          "-", RowBox[{"2", " ", "shat", " ", "mass1Squared"}], "-", 
          RowBox[{"2", " ", "shat", " ", "mass2Squared"}], "-", 
          RowBox[{"2", " ", "mass1Squared", " ", "mass2Squared"}]}]}], ";", 
      RowBox[{RowBox[{"rhoPiece", "[", RowBox[{"shat_", ",", "mi_", ",", 
            "mj_", ",", "ei_"}], "]"}], ":=", 
        RowBox[{"-", FractionBox[RowBox[{"3", " ", "ei", " ", 
             RowBox[{"(", RowBox[{RowBox[{"2", " ", "mi", " ", RowBox[
                    {"Log", "[", FractionBox[RowBox[{"shat", "-", 
                        SuperscriptBox["mj", "2"], "+", SuperscriptBox["mi", 
