Notebook[
 {
  Cell[
   "Ds/Bs gamma: current, Wick contraction, propagators, and hard traces", 
   "Title"], Cell["Step-by-step Mathematica/FeynCalc derivation", 
   "Subtitle"], Cell["This notebook is the interactive companion to the batch \
audit scripts. Evaluate the input cells from top to bottom. It follows \
Rohrwild's vacuum three-point/background-field convention, so the final \
channel carries p and the initial channel carries pPrime=p+q. The legacy \
k-p+q strange-line routing is retained only as a diagnostic comparison near \
the end.", "Text"], Cell["1. Initialization and conventions", "Section"], 
  Cell["Load FeynCalc and clear only symbols used in this notebook. Feynman \
parameters are declared scalar coefficients for shifted-momentum algebra.", 
   "Text"], 
  Cell[BoxData[RowBox[{RowBox[{"Needs", "[", "\"FeynCalc`\"", "]"}], ";", 
      RowBox[{"ClearAll", "[", RowBox[{"mu", ",", "nu", ",", "alpha", ",", 
          "beta", ",", "rho", ",", "lambda", ",", "p", ",", "q", ",", 
          "pPrime", ",", "k", ",", "l", ",", "eps", ",", "mQ", ",", "ms", 
          ",", "mb", ",", "eQ", ",", "eS", ",", "theta", ",", "Nc", ",", 
          "p2", ",", "pPrime2", ",", "pq", ",", "dH1", ",", "dH2", ",", 
          "dH3", ",", "dS1", ",", "dS2", ",", "dS3", ",", "x", ",", "y", ",", 
          "z", ",", "xi", ",", "x2", ",", "mf", ",", "ef", ",", "gs", ",", 
          "eta", ",", "M2", ",", "ssCond", ",", "Ffield", ",", "Gfield", ",", 
          "fA", ",", "fB", ",", "f1", ",", "f2", ",", "gA", ",", "gB", ",", 
          "g1", ",", "g2", ",", "tA", ",", "tB", ",", "piAA", ",", "piAB", 
          ",", "piBB", ",", "m1", ",", "m2", ",", "mP", ",", "fP", ",", 
          "borel1", ",", "borel2", ",", "borelTwoPoint", ",", "alphaEM", ",", 
          "s", ",", "s0", ",", "u0", ",", "chiC", ",", "chiGamma", ",", 
          "f3Gamma", ",", "rhoA", ",", "phiGamma", ",", "A4", ",", 
          "HbarGamma", ",", "PsiV", ",", "IF1", ",", "tAHat", ",", "tBHat", 
          ",", "tBpert", ",", "tBLocal", ",", "tBTw2", ",", "tBTw3", ",", 
          "tBTw4", ",", "tB3p", ",", "shat", ",", "mi", ",", "mj", ",", "ei", 
          ",", "u", ",", "w", ",", "v", ",", "alphaG", ",", "uval", ",", 
          "kallenLambda", ",", "rhoPiece", ",", "F1DA", ",", "hGamma", ",", 
          "psiV", ",", "uBar", ",", "muRen", ",", "gammaE", ",", "rhoAB", 
          ",", "rhoDiag", ",", "rhoFromF1", ",", "f1ModelSquared", ",", 
          "f2ModelSquared", ",", "f2FromF1Anchor", ",", "rhoFromF1Residual", 
          ",", "rhoDiagResidual", ",", "pi12Model", ",", "dsFoundResidues", 
          ",", "bsFoundResidues", ",", "piAAPert", ",", "piBBPert", ",", 
          "piABPert", ",", "piAACond", ",", "piBBCond", ",", "piABCond", ",", 
          "sThreshold", ",", "twoPointOPE11", ",", "twoPointOPE22", ",", 
          "xCoord", ",", "yCoord", ",", "zCoord", ",", "Int4", ",", "dot", 
          ",", "VEV", ",", "TimeOrder", ",", "JPdagger", ",", "JX", ",", 
          "jEM", ",", "VEVF", ",", "Fplane", ",", "Pi3Point"}], "]"}], ";", 
      RowBox[{RowBox[{"(", RowBox[{RowBox[{"(", RowBox[{RowBox[
                 {"FeynCalc`DataType", "[", RowBox[{"#1", ",", 
                    "FeynCalc`FCVariable"}], "]"}], "=", "True"}], ")"}], 
            "&"}], ")"}], "/@", RowBox[{"{", RowBox[{"x", ",", "y", ",", 
            "z"}], "}"}]}], ";", "FeynCalc`$LeviCivitaSign"}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"kinematicRules", "=", 
        RowBox[{"{", RowBox[{RowBox[{RowBox[{"SP", "[", RowBox[{"q", ",", 
                  "q"}], "]"}], "\[Rule]", "0"}], ",", 
            RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", 
                    "q", "]"}], ",", RowBox[{"Momentum", "[", "q", "]"}]}], 
                "]"}], "\[Rule]", "0"}], ",", RowBox[{RowBox[{"Pair", "[", 
                RowBox[{RowBox[{"Momentum", "[", "p", "]"}], ",", 
                  RowBox[{"Momentum", "[", "p", "]"}]}], "]"}], "\[Rule]", 
              "p2"}], ",", RowBox[{RowBox[{"Pair", "[", RowBox[
                 {RowBox[{"Momentum", "[", "p", "]"}], ",", RowBox[
                   {"Momentum", "[", "q", "]"}]}], "]"}], "\[Rule]", "pq"}], 
            ",", RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", 
                    "[", "q", "]"}], ",", RowBox[{"Momentum", "[", "p", 
                    "]"}]}], "]"}], "\[Rule]", "pq"}], ",", 
            RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", 
                    "k", "]"}], ",", RowBox[{"Momentum", "[", "pPrime", 
                    "]"}]}], "]"}], "\[Rule]", RowBox[{RowBox[{"Pair", "[", 
                  RowBox[{RowBox[{"Momentum", "[", "k", "]"}], ",", 
                    RowBox[{"Momentum", "[", "p", "]"}]}], "]"}], "+", 
                RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", "k", 
                      "]"}], ",", RowBox[{"Momentum", "[", "q", "]"}]}], 
                  "]"}]}]}], ",", RowBox[{RowBox[{"Pair", "[", 
                RowBox[{RowBox[{"Momentum", "[", "p", "]"}], ",", 
                  RowBox[{"Momentum", "[", "pPrime", "]"}]}], "]"}], 
              "\[Rule]", RowBox[{RowBox[{"Pair", "[", RowBox[
                   {RowBox[{"Momentum", "[", "p", "]"}], ",", RowBox[
                     {"Momentum", "[", "p", "]"}]}], "]"}], "+", 
                RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", "p", 
                      "]"}], ",", RowBox[{"Momentum", "[", "q", "]"}]}], 
                  "]"}]}]}], ",", RowBox[{RowBox[{"Pair", "[", 
                RowBox[{RowBox[{"Momentum", "[", "pPrime", "]"}], ",", 
                  RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], "\[Rule]", 
              RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", "p", 
                    "]"}], ",", RowBox[{"Momentum", "[", "q", "]"}]}], 
                "]"}]}]}], "}"}]}], ";", RowBox[{"pPrime2Rule", "=", 
        RowBox[{"pq", "\[Rule]", FractionBox[RowBox[{"pPrime2", "-", "p2"}], 
           "2"]}]}], ";"}]], "Input"], Cell["2. Interpolating currents", 
   "Section"], Cell["J_A is the axial-vector basis current and J_B is the \
derivative/tensor basis current. The momentum in J_B is the initial-state \
momentum pPrime=p+q.", "Text"], 
  Cell[BoxData[RowBox[{RowBox[{RowBox[{"gammaA", "[", "index_", "]"}], ":=", 
        RowBox[{RowBox[{"GA", "[", "index", "]"}], ".", 
          RowBox[{"GA", "[", "5", "]"}]}]}], ";", 
      RowBox[{RowBox[{"gammaB", "[", "index_", "]"}], ":=", 
        FractionBox[RowBox[{"\[ImaginaryI]", " ", 
           RowBox[{"FV", "[", RowBox[{"pPrime", ",", "alpha"}], "]"}], " ", 
           RowBox[{RowBox[{"DiracSigma", "[", RowBox[{RowBox[{"GA", "[", 
                   "index", "]"}], ",", RowBox[{"GA", "[", "alpha", "]"}]}], 
               "]"}], ".", RowBox[{"GA", "[", "5", "]"}]}]}], 
         RowBox[{"mQ", "+", "ms"}]]}], ";", 
      RowBox[{RowBox[{"gammaBExpanded", "[", "index_", "]"}], ":=", 
        RowBox[{"-", FractionBox[RowBox[{RowBox[{"(", RowBox[
                {RowBox[{RowBox[{"GA", "[", "index", "]"}], ".", RowBox[
                    {"GS", "[", "pPrime", "]"}]}], "-", RowBox[
                  {RowBox[{"GS", "[", "pPrime", "]"}], ".", RowBox[
                    {"GA", "[", "index", "]"}]}]}], ")"}], ".", 
             RowBox[{"GA", "[", "5", "]"}]}], RowBox[{"2", " ", 
             RowBox[{"(", RowBox[{"mQ", "+", "ms"}], ")"}]}]]}]}], ";", 
      RowBox[{RowBox[{"gammaP", "[", "]"}], ":=", 
        RowBox[{"\[ImaginaryI]", " ", RowBox[{"GA", "[", "5", "]"}]}]}], ";", 
      RowBox[{RowBox[{"gammaLow", "[", "index_", "]"}], ":=", 
        RowBox[{RowBox[{RowBox[{"Sin", "[", "theta", "]"}], " ", 
            RowBox[{"gammaA", "[", "index", "]"}]}], "+", 
          RowBox[{RowBox[{"Cos", "[", "theta", "]"}], " ", 
            RowBox[{"gammaB", "[", "index", "]"}]}]}]}], ";", 
      RowBox[{RowBox[{"gammaHigh", "[", "index_", "]"}], ":=", 
        RowBox[{RowBox[{RowBox[{"Cos", "[", "theta", "]"}], " ", 
            RowBox[{"gammaA", "[", "index", "]"}]}], "-", 
          RowBox[{RowBox[{"Sin", "[", "theta", "]"}], " ", 
            RowBox[{"gammaB", "[", "index", "]"}]}]}]}], ";", 
      RowBox[{RowBox[{"propNumerator", "[", RowBox[{"momentum_", ",", 
            "mass_"}], "]"}], ":=", RowBox[
         {RowBox[{"GS", "[", "momentum", "]"}], "+", "mass"}]}], ";"}]], 
   "Input"], Cell[BoxData[RowBox[{"tensorVertexResidual", "=", 
      RowBox[{"Simplify", "[", RowBox[{"Contract", "[", 
          RowBox[{"DiracSimplify", "[", RowBox[{RowBox[{"gammaB", "[", "mu", 
                "]"}], "-", RowBox[{"gammaBExpanded", "[", "mu", "]"}]}], 
            "]"}], "]"}], "]"}]}]], "Input"], 
  Cell["3. Correlator and Wick contraction", "Section"], 
  Cell["Use Rohrwild's vacuum three-point correlator Pi_X,munu = i^2 \
Integral_x Integral_y exp(i p.x+i q.y)<0|T{J_P^dagger(x) j_em,nu(y) \
J_X,mu(0)}|0>. The external-photon correlator is its term linear in the \
plane-wave background field. A full contraction gives one closed fermion \
loop: <sbar Gamma_P Q Qbar Gamma_X s> = -Tr[Gamma_P S_Q Gamma_X S_s].", 
   "Text"], 
  Cell[BoxData[RowBox[{RowBox[{"rohrwildThreePoint", "=", 
        RowBox[{SuperscriptBox["\[ImaginaryI]", "2"], " ", 
          RowBox[{"Int4", "[", "xCoord", "]"}], " ", 
          RowBox[{"Int4", "[", "yCoord", "]"}], " ", 
          RowBox[{"Exp", "[", RowBox[{RowBox[{"\[ImaginaryI]", " ", 
                RowBox[{"dot", "[", RowBox[{"p", ",", "xCoord"}], "]"}]}], 
              "+", RowBox[{"\[ImaginaryI]", " ", RowBox[{"dot", "[", 
                  RowBox[{"q", ",", "yCoord"}], "]"}]}]}], "]"}], " ", 
          RowBox[{"VEV", "[", RowBox[{"TimeOrder", "[", RowBox[{
                RowBox[{"JPdagger", "[", "xCoord", "]"}], ",", 
                RowBox[{"jEM", "[", RowBox[{"nu", ",", "yCoord"}], "]"}], 
                ",", RowBox[{"JX", "[", RowBox[{"mu", ",", "0"}], "]"}]}], 
              "]"}], "]"}]}]}], ";", 
      RowBox[{RowBox[{"Fplane", "[", RowBox[{"alpha_", ",", "beta_", ",", 
            "zCoord_"}], "]"}], ":=", RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"(", RowBox[{RowBox[{RowBox[{"FV", "[", RowBox[{"q", ",", 
                    "alpha"}], "]"}], " ", RowBox[{"FV", "[", RowBox[
                   {"eps", ",", "beta"}], "]"}]}], "-", RowBox[{
                RowBox[{"FV", "[", RowBox[{"q", ",", "beta"}], "]"}], " ", 
                RowBox[{"FV", "[", RowBox[{"eps", ",", "alpha"}], "]"}]}]}], 
            ")"}], " ", RowBox[{"Exp", "[", RowBox[{"\[ImaginaryI]", " ", 
              RowBox[{"dot", "[", RowBox[{"q", ",", "zCoord"}], "]"}]}], 
            "]"}]}]}], ";", RowBox[{"rohrwildBackground", "=", 
        RowBox[{"\[ImaginaryI]", " ", RowBox[{"Int4", "[", "xCoord", "]"}], 
          " ", RowBox[{"Exp", "[", RowBox[{"\[ImaginaryI]", " ", 
              RowBox[{"dot", "[", RowBox[{"p", ",", "xCoord"}], "]"}]}], 
            "]"}], " ", RowBox[{"VEVF", "[", RowBox[{RowBox[{"TimeOrder", 
                "[", RowBox[{RowBox[{"JPdagger", "[", "xCoord", "]"}], ",", 
                  RowBox[{"JX", "[", RowBox[{"mu", ",", "0"}], "]"}]}], 
                "]"}], ",", "Fplane"}], "]"}]}]}], ";", 
      RowBox[{"Association", "[", RowBox[{RowBox[{"\"Pi_X,munu(p,q)\"", 
            "\[Rule]", "rohrwildThreePoint"}], ",", 
          RowBox[{"\"epsilon^nu Pi_X,munu: term linear in F\"", "\[Rule]", 
            "rohrwildBackground"}], ",", RowBox[{"\"initial momentum\"", 
            "\[Rule]", RowBox[{"pPrime", "\[Equal]", RowBox[{"p", "+", 
                "q"}]}]}]}], "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"fermionLoopSign", "=", RowBox[{"-", "1"}]}], 
      ";", RowBox[{"hardWickPrefactor", "=", RowBox[{"\[ImaginaryI]", " ", 
          "fermionLoopSign", " ", "Nc"}]}], ";", 
      RowBox[{"softWickPrefactorBeforeFierz", "=", "\[ImaginaryI]"}], ";", 
      RowBox[{"softWickPrefactorAfterFierz", "=", 
        RowBox[{"-", FractionBox["\[ImaginaryI]", "4"]}]}], ";", 
      RowBox[{"Association", "[", RowBox[
         {RowBox[{"\"hard before propagator and QED factors\"", "\[Rule]", 
            "hardWickPrefactor"}], ",", RowBox[{"\"soft before Fierz\"", 
            "\[Rule]", "softWickPrefactorBeforeFierz"}], ",", 
          RowBox[{"\"soft after Fierz\"", "\[Rule]", 
            "softWickPrefactorAfterFierz"}]}], "]"}]}]], "Input"], 
  Cell["4. Propagators without local parts and calculation warning", 
   "Section"], Cell["Local vacuum-condensate pieces are deliberately not \
written in the propagators. The displayed expressions contain only the free \
massive term and the electromagnetic and one-gluon background-field kernels. \
IMPORTANT: the existing axial numerical calculation still includes the \
contribution named heavy_local; it has not been removed.", "Text"], 
  Cell[BoxData[RowBox[{RowBox[{RowBox[{"freePropagator", "[", 
          RowBox[{"momentum_", ",", "mass_"}], "]"}], ":=", 
        FractionBox[RowBox[{"\[ImaginaryI]", " ", 
           RowBox[{"(", RowBox[{RowBox[{"GS", "[", "momentum", "]"}], "+", 
               "mass"}], ")"}]}], RowBox[
          {RowBox[{"SP", "[", RowBox[{"momentum", ",", "momentum"}], "]"}], 
           "-", SuperscriptBox["mass", "2"], "+", RowBox[{"\[ImaginaryI]", 
             " ", "eta"}]}]]}], ";", RowBox[{"lightStrangeFreeTerms", "=", 
        RowBox[{"Association", "[", RowBox[{RowBox[{"\"free massless\"", 
              "\[Rule]", FractionBox[RowBox[{"\[ImaginaryI]", " ", 
                 RowBox[{"GS", "[", "xi", "]"}]}], RowBox[{"2", " ", 
                 SuperscriptBox["\[Pi]", "2"], " ", SuperscriptBox["x2", 
                  "2"]}]]}], ",", RowBox[{"\"explicit strange mass\"", 
              "\[Rule]", RowBox[{"-", FractionBox["ms", RowBox[{"4", " ", 
                   SuperscriptBox["\[Pi]", "2"], " ", "x2"}]]}]}]}], "]"}]}], 
      ";", RowBox[{"uBar", "=", RowBox[{"1", "-", "u"}]}], ";", 
      RowBox[{"rohrwildLightBackgroundTerms", "=", 
        RowBox[{"Association", "[", RowBox[
           {RowBox[{"\"gluon, Rohrwild massless kernel\"", "\[Rule]", 
              RowBox[{"-", FractionBox[RowBox[{"\[ImaginaryI]", " ", "gs", 
                   " ", TemplateBox[{RowBox[{RowBox[{"(", RowBox[{RowBox[
                          {"uBar", " ", RowBox[{RowBox[{"GS", "[", "xi", 
                          "]"}], ".", RowBox[{"DiracSigma", "[", RowBox[
                          {RowBox[{"GA", "[", "alpha", "]"}], ",", RowBox[
                          {"GA", "[", "beta", "]"}]}], "]"}]}]}], "+", 
                          RowBox[{"u", " ", RowBox[{RowBox[{"DiracSigma", 
                          "[", RowBox[{RowBox[{"GA", "[", "alpha", "]"}], 
                          ",", RowBox[{"GA", "[", "beta", "]"}]}], "]"}], 
                          ".", RowBox[{"GS", "[", "xi", "]"}]}]}]}], ")"}], 
                       " ", RowBox[{"Gfield", "[", RowBox[{"alpha", ",", 
                          "beta", ",", "u"}], "]"}]}], "u", "0", "1"}, 
                    "InactiveIntegrate", DisplayFunction -> (RowBox[
                       {SubsuperscriptBox[StyleBox["\[Integral]", 
                          "Inactive"], #3, #4], RowBox[{#1, RowBox[
                          {StyleBox["\[DifferentialD]", "Inactive"], 
                          #2}]}]}] & ), InterpretationFunction -> 
                     (RowBox[{RowBox[{"Inactive", "[", "Integrate", "]"}], 
                        "[", RowBox[{#1, ",", RowBox[{"{", RowBox[{#2, ",", 
                          #3, ",", #4}], "}"}]}], "]"}] & )]}], 
                 RowBox[{"16", " ", SuperscriptBox["\[Pi]", "2"], " ", 
                   "x2"}]]}]}], ",", RowBox[
             {"\"photon, Rohrwild massless kernel\"", "\[Rule]", 
              RowBox[{"-", FractionBox[RowBox[{"\[ImaginaryI]", " ", "eS", 
                   " ", TemplateBox[{RowBox[{RowBox[{"(", RowBox[{RowBox[
                          {"uBar", " ", RowBox[{RowBox[{"GS", "[", "xi", 
                          "]"}], ".", RowBox[{"DiracSigma", "[", RowBox[
                          {RowBox[{"GA", "[", "alpha", "]"}], ",", RowBox[
                          {"GA", "[", "beta", "]"}]}], "]"}]}]}], "+", 
                          RowBox[{"u", " ", RowBox[{RowBox[{"DiracSigma", 
                          "[", RowBox[{RowBox[{"GA", "[", "alpha", "]"}], 
                          ",", RowBox[{"GA", "[", "beta", "]"}]}], "]"}], 
                          ".", RowBox[{"GS", "[", "xi", "]"}]}]}]}], ")"}], 
                       " ", RowBox[{"Ffield", "[", RowBox[{"alpha", ",", 
                          "beta", ",", "u"}], "]"}]}], "u", "0", "1"}, 
                    "InactiveIntegrate", DisplayFunction -> (RowBox[
                       {SubsuperscriptBox[StyleBox["\[Integral]", 
                          "Inactive"], #3, #4], RowBox[{#1, RowBox[
                          {StyleBox["\[DifferentialD]", "Inactive"], 
                          #2}]}]}] & ), InterpretationFunction -> 
                     (RowBox[{RowBox[{"Inactive", "[", "Integrate", "]"}], 
                        "[", RowBox[{#1, ",", RowBox[{"{", RowBox[{#2, ",", 
                          #3, ",", #4}], "}"}]}], "]"}] & )]}], 
                 RowBox[{"16", " ", SuperscriptBox["\[Pi]", "2"], " ", 
                   "x2"}]]}]}], ",", RowBox[
             {"\"linear-ms background correction\"", "\[Rule]", 
              RowBox[{"-", FractionBox[RowBox[{"ms", " ", TemplateBox[
                    {RowBox[{RowBox[{"(", RowBox[{RowBox[{"gs", " ", RowBox[
                          {"Gfield", "[", RowBox[{"alpha", ",", "beta", ",", 
                          "u"}], "]"}]}], "+", RowBox[{"eS", " ", RowBox[
                          {"Ffield", "[", RowBox[{"alpha", ",", "beta", ",", 
                          "u"}], "]"}]}]}], ")"}], " ", RowBox[{"DiracSigma", 
                         "[", RowBox[{RowBox[{"GA", "[", "alpha", "]"}], ",", 
                          RowBox[{"GA", "[", "beta", "]"}]}], "]"}], " ", 
                       RowBox[{"(", RowBox[{RowBox[{"Log", "[", RowBox[
                          {FractionBox["1", "4"], " ", RowBox[{"(", RowBox[
                          {"-", "x2"}], ")"}], " ", SuperscriptBox["muRen", 
                          "2"]}], "]"}], "+", RowBox[{"2", " ", "gammaE"}]}], 
                         ")"}]}], "u", "0", "1"}, "InactiveIntegrate", 
                    DisplayFunction -> (RowBox[{SubsuperscriptBox[StyleBox[
                          "\[Integral]", "Inactive"], #3, #4], RowBox[
                         {#1, RowBox[{StyleBox["\[DifferentialD]", 
                          "Inactive"], #2}]}]}] & ), 
                    InterpretationFunction -> (RowBox[{RowBox[{"Inactive", 
                          "[", "Integrate", "]"}], "[", RowBox[{#1, ",", 
                          RowBox[{"{", RowBox[{#2, ",", #3, ",", #4}], 
                          "}"}]}], "]"}] & )]}], RowBox[{"32", " ", 
                   SuperscriptBox["\[Pi]", "2"]}]]}]}]}], "]"}]}], ";", 
      RowBox[{"Association", "[", RowBox[
         {RowBox[{"\"S_s free massive part\"", "\[Rule]", 
            "lightStrangeFreeTerms"}], ",", RowBox[
           {"\"S_s Rohrwild G/F terms plus ms correction\"", "\[Rule]", 
            "rohrwildLightBackgroundTerms"}], ",", 
          RowBox[{"\"WARNING\"", "\[Rule]", "\"legacy/current axial numerical \
results include heavy_local; mixed and vacuum-G2 terms are absent\""}]}], 
        "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"electromagneticBackgroundKernel", "=", 
        RowBox[{RowBox[{"-", "\[ImaginaryI]"}], " ", "ef", " ", 
          RowBox[{"(", RowBox[{FractionBox[RowBox[{RowBox[{"(", RowBox[
                    {RowBox[{"GS", "[", "k", "]"}], "+", "mf"}], ")"}], " ", 
                 RowBox[{"Ffield", "[", RowBox[{"alpha", ",", "rho", ",", 
                     "u"}], "]"}], " ", RowBox[{"DiracSigma", "[", 
                   RowBox[{RowBox[{"GA", "[", "alpha", "]"}], ",", RowBox[
                      {"GA", "[", "rho", "]"}]}], "]"}]}], RowBox[
                {"2", " ", SuperscriptBox[RowBox[{"(", RowBox[{SuperscriptBox[
                       "mf", "2"], "-", RowBox[{"SP", "[", RowBox[{"k", ",", 
                          "k"}], "]"}]}], ")"}], "2"]}]], "+", 
              FractionBox[RowBox[{"u", " ", RowBox[{"FV", "[", RowBox[
                    {"xi", ",", "alpha"}], "]"}], " ", RowBox[{"Ffield", "[", 
                   RowBox[{"alpha", ",", "rho", ",", "u"}], "]"}], " ", 
                 RowBox[{"GA", "[", "rho", "]"}]}], RowBox[{SuperscriptBox[
                  "mf", "2"], "-", RowBox[{"SP", "[", RowBox[{"k", ",", 
                     "k"}], "]"}]}]]}], ")"}]}]}], ";", 
      RowBox[{"oneGluonBackgroundKernel", "=", 
        RowBox[{RowBox[{"-", "\[ImaginaryI]"}], " ", "gs", " ", 
          RowBox[{"(", RowBox[{FractionBox[RowBox[{RowBox[{"(", RowBox[
                    {RowBox[{"GS", "[", "k", "]"}], "+", "mQ"}], ")"}], " ", 
                 RowBox[{"Gfield", "[", RowBox[{"alpha", ",", "rho", ",", 
                     "u"}], "]"}], " ", RowBox[{"DiracSigma", "[", 
                   RowBox[{RowBox[{"GA", "[", "alpha", "]"}], ",", RowBox[
                      {"GA", "[", "rho", "]"}]}], "]"}]}], RowBox[
                {"2", " ", SuperscriptBox[RowBox[{"(", RowBox[{SuperscriptBox[
                       "mQ", "2"], "-", RowBox[{"SP", "[", RowBox[{"k", ",", 
                          "k"}], "]"}]}], ")"}], "2"]}]], "+", 
              FractionBox[RowBox[{"u", " ", RowBox[{"FV", "[", RowBox[
                    {"xi", ",", "alpha"}], "]"}], " ", RowBox[{"Gfield", "[", 
                   RowBox[{"alpha", ",", "rho", ",", "u"}], "]"}], " ", 
                 RowBox[{"GA", "[", "rho", "]"}]}], RowBox[{SuperscriptBox[
                  "mQ", "2"], "-", RowBox[{"SP", "[", RowBox[{"k", ",", 
                     "k"}], "]"}]}]]}], ")"}]}]}], ";", 
      RowBox[{"propagatorTermStatus", "=", RowBox[{"Association", "[", 
          RowBox[{RowBox[{"\"free propagators\"", "\[Rule]", 
              "\"independently used in Mathematica\""}], ",", 
            RowBox[{"\"explicit strange mass\"", "\[Rule]", 
              "\"kept in free and linear background terms\""}], ",", 
            RowBox[{"\"local <sbar s> axial term\"", "\[Rule]", 
              "\"not displayed here; included in existing axial numerics\""}]\
, ",", RowBox[{"\"electromagnetic background field\"", "\[Rule]", 
              "\"hard traces derived; loop stage pending\""}], ",", 
            RowBox[{"\"one-gluon background field\"", "\[Rule]", 
              "\"A and B trace kernels derived\""}], ",", 
            RowBox[{"\"mixed condensate\"", "\[Rule]", 
              "\"not included in radiative three-point sum rule\""}], ",", 
            RowBox[{"\"vacuum gluon condensate\"", "\[Rule]", 
              "\"not included in radiative three-point sum rule\""}]}], 
          "]"}]}], ";", RowBox[{"Association", "[", 
        RowBox[{RowBox[{"\"S^gamma kernel\"", "\[Rule]", 
            "electromagneticBackgroundKernel"}], ",", 
          RowBox[{"\"S^G kernel\"", "\[Rule]", "oneGluonBackgroundKernel"}], 
          ",", RowBox[{"\"status\"", "\[Rule]", "propagatorTermStatus"}]}], 
        "]"}]}]], "Input"], Cell["5. Propagator routing", "Section"], 
  Cell["The two vertex constraints are checked before any trace: final \
momentum p at J_P^dagger and initial momentum pPrime=p+q at J_X.", "Text"], 
  Cell[BoxData[RowBox[{RowBox[{"heavyVertexMomenta", "=", 
        RowBox[{"{", RowBox[{RowBox[{"k", "-", RowBox[{"(", RowBox[
                 {"k", "-", "p"}], ")"}]}], ",", RowBox[
             {RowBox[{"(", RowBox[{"k", "+", "q"}], ")"}], "-", 
              RowBox[{"(", RowBox[{"k", "-", "p"}], ")"}]}]}], "}"}]}], ";", 
      RowBox[{"strangeVertexMomenta", "=", 
        RowBox[{"{", RowBox[{RowBox[{"k", "-", RowBox[{"(", RowBox[
                 {"k", "-", "p"}], ")"}]}], ",", RowBox[{"k", "-", 
              RowBox[{"(", RowBox[{"k", "-", "p", "-", "q"}], ")"}]}]}], 
          "}"}]}], ";", RowBox[{"Association", "[", 
        RowBox[{RowBox[{"\"heavy: {final, initial}\"", "\[Rule]", 
            "heavyVertexMomenta"}], ",", RowBox[
           {"\"strange: {final, initial}\"", "\[Rule]", 
            "strangeVertexMomenta"}], ",", RowBox[{"\"required\"", "\[Rule]", 
            RowBox[{"{", RowBox[{"p", ",", RowBox[{"p", "+", "q"}]}], 
              "}"}]}]}], "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"heavyDenominators", "=", 
        RowBox[{"{", RowBox[{RowBox[{"dH1", "\[Rule]", RowBox[{
                RowBox[{"SP", "[", RowBox[{RowBox[{"k", "+", "q"}], ",", 
                    RowBox[{"k", "+", "q"}]}], "]"}], "-", SuperscriptBox[
                 "mQ", "2"]}]}], ",", RowBox[{"dH2", "\[Rule]", 
              RowBox[{RowBox[{"SP", "[", RowBox[{"k", ",", "k"}], "]"}], "-", 
                SuperscriptBox["mQ", "2"]}]}], ",", RowBox[{"dH3", "\[Rule]", 
              RowBox[{RowBox[{"SP", "[", RowBox[{RowBox[{"k", "-", "p"}], 
                    ",", RowBox[{"k", "-", "p"}]}], "]"}], "-", 
                SuperscriptBox["ms", "2"]}]}]}], "}"}]}], ";", 
      RowBox[{"strangeDenominators", "=", 
        RowBox[{"{", RowBox[{RowBox[{"dS1", "\[Rule]", RowBox[{
                RowBox[{"SP", "[", RowBox[{"k", ",", "k"}], "]"}], "-", 
                SuperscriptBox["mQ", "2"]}]}], ",", RowBox[{"dS2", "\[Rule]", 
              RowBox[{RowBox[{"SP", "[", RowBox[{RowBox[{"k", "-", "p"}], 
                    ",", RowBox[{"k", "-", "p"}]}], "]"}], "-", 
                SuperscriptBox["ms", "2"]}]}], ",", RowBox[{"dS3", "\[Rule]", 
              RowBox[{RowBox[{"SP", "[", RowBox[{RowBox[{"k", "-", "p", "-", 
                      "q"}], ",", RowBox[{"k", "-", "p", "-", "q"}]}], "]"}], 
                "-", SuperscriptBox["ms", "2"]}]}]}], "}"}]}], ";", 
      RowBox[{"{", RowBox[{"heavyDenominators", ",", "strangeDenominators"}], 
        "}"}]}]], "Input"], Cell["Fermion-line Ward identities", 
   "Subsection"], 
  Cell[BoxData[RowBox[{RowBox[{"wardHeavyLHS", "=", 
        RowBox[{"DiracGammaExpand", "[", RowBox[
           {RowBox[{"propNumerator", "[", RowBox[{"k", ",", "mQ"}], "]"}], 
            ".", RowBox[{"GS", "[", "q", "]"}], ".", 
            RowBox[{"propNumerator", "[", RowBox[{RowBox[{"k", "+", "q"}], 
                ",", "mQ"}], "]"}]}], "]"}]}], ";", 
      RowBox[{"wardHeavyRHS", "=", RowBox[
         {RowBox[{RowBox[{"(", RowBox[{RowBox[{"SP", "[", RowBox[
                   {RowBox[{"k", "+", "q"}], ",", RowBox[{"k", "+", "q"}]}], 
                  "]"}], "-", SuperscriptBox["mQ", "2"]}], ")"}], " ", 
            RowBox[{"propNumerator", "[", RowBox[{"k", ",", "mQ"}], "]"}]}], 
          "-", RowBox[{RowBox[{"(", RowBox[{RowBox[{"SP", "[", RowBox[
                   {"k", ",", "k"}], "]"}], "-", SuperscriptBox["mQ", "2"]}], 
              ")"}], " ", RowBox[{"propNumerator", "[", RowBox[{
                RowBox[{"k", "+", "q"}], ",", "mQ"}], "]"}]}]}]}], ";", 
      RowBox[{"wardHeavyResidual", "=", RowBox[{"Simplify", "[", 
          RowBox[{"ScalarProductExpand", "[", RowBox[{"FCE", "[", 
              RowBox[{"DiracSimplify", "[", RowBox[{RowBox[
                   {"DiracGammaExpand", "[", RowBox[{"FCI", "[", RowBox[
                       {"wardHeavyLHS", "-", "wardHeavyRHS"}], "]"}], "]"}], 
                  ",", RowBox[{"DiracSubstitute67", "\[Rule]", "True"}], ",", 
                  RowBox[{"DiracOrder", "\[Rule]", "True"}]}], "]"}], "]"}], 
            "]"}], "]"}]}], ";", "wardHeavyResidual"}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"wardStrangeLHS", "=", 
        RowBox[{"DiracGammaExpand", "[", RowBox[
           {RowBox[{"propNumerator", "[", RowBox[{RowBox[{"l", "-", "q"}], 
                ",", "ms"}], "]"}], ".", RowBox[{"GS", "[", "q", "]"}], ".", 
            RowBox[{"propNumerator", "[", RowBox[{"l", ",", "ms"}], "]"}]}], 
          "]"}]}], ";", RowBox[{"wardStrangeRHS", "=", 
        RowBox[{RowBox[{RowBox[{"(", RowBox[{RowBox[{"SP", "[", RowBox[
                   {"l", ",", "l"}], "]"}], "-", SuperscriptBox["ms", "2"]}], 
              ")"}], " ", RowBox[{"propNumerator", "[", RowBox[{
                RowBox[{"l", "-", "q"}], ",", "ms"}], "]"}]}], "-", 
          RowBox[{RowBox[{"(", RowBox[{RowBox[{"SP", "[", RowBox[
                   {RowBox[{"l", "-", "q"}], ",", RowBox[{"l", "-", "q"}]}], 
                  "]"}], "-", SuperscriptBox["ms", "2"]}], ")"}], " ", 
            RowBox[{"propNumerator", "[", RowBox[{"l", ",", "ms"}], 
              "]"}]}]}]}], ";", RowBox[{"wardStrangeResidual", "=", 
        RowBox[{"Simplify", "[", RowBox[{"ScalarProductExpand", "[", 
            RowBox[{"FCE", "[", RowBox[{"DiracSimplify", "[", RowBox[
                 {RowBox[{"DiracGammaExpand", "[", RowBox[{"FCI", "[", 
                      RowBox[{"wardStrangeLHS", "-", "wardStrangeRHS"}], 
                      "]"}], "]"}], ",", RowBox[{"DiracSubstitute67", 
                    "\[Rule]", "True"}], ",", RowBox[{"DiracOrder", 
                    "\[Rule]", "True"}]}], "]"}], "]"}], "]"}], "]"}]}], ";", 
      "wardStrangeResidual"}]], "Input"], 
  Cell["6. Hard-emission Dirac traces", "Section"], 
  Cell["Charges, denominators, color, QED vertices, and propagator factors \
remain outside these numerator traces. Each topology is evaluated \
separately.", "Text"], 
  Cell[BoxData[RowBox[{RowBox[{RowBox[{"traceReduce", "[", "expression_", 
          "]"}], ":=", RowBox[{"Collect2", "[", 
          RowBox[{RowBox[{"DiracSimplify", "[", RowBox[{"expression", ",", 
                RowBox[{"DiracSubstitute67", "\[Rule]", "True"}]}], "]"}], 
            ",", RowBox[{"{", RowBox[{"mQ", ",", "ms"}], "}"}]}], "]"}]}], 
      ";", RowBox[{RowBox[{"heavyTrace", "[", "current_", "]"}], ":=", 
        RowBox[{"traceReduce", "[", RowBox[{"DiracTrace", "[", 
            RowBox[{RowBox[{"gammaP", "[", "]"}], ".", RowBox[{
                "propNumerator", "[", RowBox[{"k", ",", "mQ"}], "]"}], ".", 
              RowBox[{"GA", "[", "nu", "]"}], ".", RowBox[{"propNumerator", 
                "[", RowBox[{RowBox[{"k", "+", "q"}], ",", "mQ"}], "]"}], 
              ".", RowBox[{"current", "[", "mu", "]"}], ".", 
              RowBox[{"propNumerator", "[", RowBox[{RowBox[{"k", "-", "p"}], 
                  ",", "ms"}], "]"}]}], "]"}], "]"}]}], ";", 
      RowBox[{RowBox[{"strangeTrace", "[", "current_", "]"}], ":=", 
        RowBox[{"traceReduce", "[", RowBox[{"DiracTrace", "[", 
            RowBox[{RowBox[{"gammaP", "[", "]"}], ".", RowBox[{
                "propNumerator", "[", RowBox[{"k", ",", "mQ"}], "]"}], ".", 
              RowBox[{"current", "[", "mu", "]"}], ".", RowBox[{
                "propNumerator", "[", RowBox[{RowBox[{"k", "-", "p", "-", 
                    "q"}], ",", "ms"}], "]"}], ".", RowBox[{"GA", "[", "nu", 
                "]"}], ".", RowBox[{"propNumerator", "[", RowBox[
                 {RowBox[{"k", "-", "p"}], ",", "ms"}], "]"}]}], "]"}], 
          "]"}]}], ";"}]], "Input"], 
  Cell[BoxData[RowBox[{"nAHeavy", "=", RowBox[{"heavyTrace", "[", "gammaA", 
        "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{"nAStrange", "=", RowBox[{"strangeTrace", "[", 
        "gammaA", "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{"nBHeavy", "=", RowBox[{"heavyTrace", "[", "gammaB", 
        "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{"nBStrange", "=", RowBox[{"strangeTrace", "[", 
        "gammaB", "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"nATotal", "=", 
        RowBox[{"Collect2", "[", RowBox[{RowBox[{RowBox[{"eQ", " ", 
                "nAHeavy"}], "+", RowBox[{"eS", " ", "nAStrange"}]}], ",", 
            RowBox[{"{", RowBox[{"eQ", ",", "eS", ",", "mQ", ",", "ms"}], 
              "}"}]}], "]"}]}], ";", RowBox[{"nBTotal", "=", 
        RowBox[{"Collect2", "[", RowBox[{RowBox[{RowBox[{"eQ", " ", 
                "nBHeavy"}], "+", RowBox[{"eS", " ", "nBStrange"}]}], ",", 
            RowBox[{"{", RowBox[{"eQ", ",", "eS", ",", "mQ", ",", "ms"}], 
              "}"}]}], "]"}]}], ";", 
      RowBox[{"{", RowBox[{"nATotal", ",", "nBTotal"}], "}"}]}]], "Input"], 
  Cell["7. E1 projection and inverse-denominator reduction", "Section"], 
  Cell[BoxData[RowBox[{RowBox[{"e1Tensor", "=", 
        RowBox[{RowBox[{RowBox[{"FV", "[", RowBox[{"p", ",", "nu"}], "]"}], 
            " ", RowBox[{"FV", "[", RowBox[{"q", ",", "mu"}], "]"}]}], "-", 
          RowBox[{RowBox[{"SP", "[", RowBox[{"p", ",", "q"}], "]"}], " ", 
            RowBox[{"MT", "[", RowBox[{"mu", ",", "nu"}], "]"}]}]}]}], ";", 
      RowBox[{"e1Projector", "=", FractionBox["e1Tensor", 
         RowBox[{"2", " ", SuperscriptBox[RowBox[{"SP", "[", RowBox[{"p", 
                ",", "q"}], "]"}], "2"]}]]}], ";", 
      RowBox[{RowBox[{"e1Project", "[", "expression_", "]"}], ":=", 
        RowBox[{"Collect2", "[", RowBox[{RowBox[{"ScalarProductExpand", "[", 
              RowBox[{RowBox[{"Contract", "[", RowBox[{"expression", " ", 
                    "e1Projector"}], "]"}], "/.", "\[VeryThinSpace]", 
                "kinematicRules"}], "]"}], ",", RowBox[
             {"{", RowBox[{"mQ", ",", "ms"}], "}"}]}], "]"}]}], ";", 
      RowBox[{"projectorNormalization", "=", RowBox[{"Simplify", "[", 
          RowBox[{"ScalarProductExpand", "[", RowBox[{RowBox[{"Contract", 
                "[", RowBox[{"e1Tensor", " ", "e1Projector"}], "]"}], "/.", 
              "\[VeryThinSpace]", "kinematicRules"}], "]"}], "]"}]}], ";", 
      RowBox[{"photonWard", "=", RowBox[{"Simplify", "[", 
          RowBox[{"ScalarProductExpand", "[", RowBox[{RowBox[{"Contract", 
                "[", RowBox[{"e1Tensor", " ", RowBox[{"FV", "[", RowBox[
                     {"q", ",", "nu"}], "]"}]}], "]"}], "/.", 
              "\[VeryThinSpace]", "kinematicRules"}], "]"}], "]"}]}], ";", 
      RowBox[{"{", RowBox[{"projectorNormalization", ",", "photonWard"}], 
        "}"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"projAHeavy", "=", 
        RowBox[{"e1Project", "[", "nAHeavy", "]"}]}], ";", 
      RowBox[{"projAStrange", "=", RowBox[{"e1Project", "[", "nAStrange", 
          "]"}]}], ";", RowBox[{"projBHeavy", "=", 
        RowBox[{"e1Project", "[", "nBHeavy", "]"}]}], ";", 
      RowBox[{"projBStrange", "=", RowBox[{"e1Project", "[", "nBStrange", 
          "]"}]}], ";"}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"heavyRules", "=", 
        RowBox[{"{", RowBox[{RowBox[{RowBox[{"Pair", "[", RowBox[
                 {RowBox[{"Momentum", "[", "p", "]"}], ",", RowBox[
                   {"Momentum", "[", "p", "]"}]}], "]"}], "\[Rule]", "p2"}], 
            ",", RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", 
                    "[", "p", "]"}], ",", RowBox[{"Momentum", "[", "q", 
                    "]"}]}], "]"}], "\[Rule]", "pq"}], ",", 
            RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", 
                    "k", "]"}], ",", RowBox[{"Momentum", "[", "k", "]"}]}], 
                "]"}], "\[Rule]", RowBox[{"dH2", "+", SuperscriptBox["mQ", 
                 "2"]}]}], ",", RowBox[{RowBox[{"Pair", "[", RowBox[
                 {RowBox[{"Momentum", "[", "k", "]"}], ",", RowBox[
                   {"Momentum", "[", "q", "]"}]}], "]"}], "\[Rule]", 
              FractionBox[RowBox[{"dH1", "-", "dH2"}], "2"]}], ",", 
            RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", 
                    "k", "]"}], ",", RowBox[{"Momentum", "[", "p", "]"}]}], 
                "]"}], "\[Rule]", RowBox[{FractionBox["1", "2"], " ", 
                RowBox[{"(", RowBox[{"dH2", "+", SuperscriptBox["mQ", "2"], 
                    "+", "p2", "-", SuperscriptBox["ms", "2"], "-", "dH3"}], 
                  ")"}]}]}]}], "}"}]}], ";", 
      RowBox[{"strangeRules", "=", RowBox[
         {"{", RowBox[{RowBox[{RowBox[{"Pair", "[", RowBox[
                 {RowBox[{"Momentum", "[", "p", "]"}], ",", RowBox[
                   {"Momentum", "[", "p", "]"}]}], "]"}], "\[Rule]", "p2"}], 
            ",", RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", 
                    "[", "p", "]"}], ",", RowBox[{"Momentum", "[", "q", 
                    "]"}]}], "]"}], "\[Rule]", "pq"}], ",", 
            RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", 
                    "k", "]"}], ",", RowBox[{"Momentum", "[", "k", "]"}]}], 
                "]"}], "\[Rule]", RowBox[{"dS1", "+", SuperscriptBox["mQ", 
                 "2"]}]}], ",", RowBox[{RowBox[{"Pair", "[", RowBox[
                 {RowBox[{"Momentum", "[", "k", "]"}], ",", RowBox[
                   {"Momentum", "[", "p", "]"}]}], "]"}], "\[Rule]", 
              RowBox[{FractionBox["1", "2"], " ", RowBox[{"(", RowBox[
                   {"dS1", "+", SuperscriptBox["mQ", "2"], "+", "p2", "-", 
                    SuperscriptBox["ms", "2"], "-", "dS2"}], ")"}]}]}], ",", 
            RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", 
                    "k", "]"}], ",", RowBox[{"Momentum", "[", "q", "]"}]}], 
                "]"}], "\[Rule]", RowBox[{"pq", "+", FractionBox[
                 RowBox[{"dS2", "-", "dS3"}], "2"]}]}]}], "}"}]}], ";", 
      RowBox[{RowBox[{"triangleCore", "[", RowBox[{"projected_", ",", 
            "rules_", ",", "denominators_"}], "]"}], ":=", 
        RowBox[{"Collect2", "[", RowBox[{RowBox[{RowBox[{"Expand", "[", 
                RowBox[{"projected", "/.", "\[VeryThinSpace]", "rules"}], 
                "]"}], "/.", "\[VeryThinSpace]", RowBox[{"Thread", "[", 
                RowBox[{"denominators", "\[Rule]", "0"}], "]"}]}], ",", 
            RowBox[{"{", RowBox[{"mQ", ",", "ms", ",", "p2", ",", "pq"}], 
              "}"}]}], "]"}]}], ";"}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"coreAHeavy", "=", 
        RowBox[{"triangleCore", "[", RowBox[{"projAHeavy", ",", "heavyRules", 
            ",", RowBox[{"{", RowBox[{"dH1", ",", "dH2", ",", "dH3"}], 
              "}"}]}], "]"}]}], ";", RowBox[{"coreAStrange", "=", 
        RowBox[{"triangleCore", "[", RowBox[{"projAStrange", ",", 
            "strangeRules", ",", RowBox[{"{", RowBox[{"dS1", ",", "dS2", ",", 
                "dS3"}], "}"}]}], "]"}]}], ";", 
      RowBox[{"coreBHeavy", "=", RowBox[{"triangleCore", "[", 
          RowBox[{"projBHeavy", ",", "heavyRules", ",", 
            RowBox[{"{", RowBox[{"dH1", ",", "dH2", ",", "dH3"}], "}"}]}], 
          "]"}]}], ";", RowBox[{"coreBStrange", "=", 
        RowBox[{"triangleCore", "[", RowBox[{"projBStrange", ",", 
            "strangeRules", ",", RowBox[{"{", RowBox[{"dS1", ",", "dS2", ",", 
                "dS3"}], "}"}]}], "]"}]}], ";", 
      RowBox[{"Association", "[", RowBox[{RowBox[{"\"A heavy\"", "\[Rule]", 
            "coreAHeavy"}], ",", RowBox[{"\"A strange\"", "\[Rule]", 
            "coreAStrange"}], ",", RowBox[{"\"B heavy\"", "\[Rule]", 
            "coreBHeavy"}], ",", RowBox[{"\"B strange\"", "\[Rule]", 
            "coreBStrange"}]}], "]"}]}]], "Input"], 
  Cell["8. Hard-loop Feynman parameterization", "Section"], 
  Cell["For x+y+z=1, each weighted denominator is completed to a square. The \
residuals below must vanish identically before loop integration.", "Text"], 
  Cell[BoxData[RowBox[{RowBox[{"parameterKinematics", "=", 
        RowBox[{"{", RowBox[{RowBox[{RowBox[{"Pair", "[", RowBox[
                 {RowBox[{"Momentum", "[", "q", "]"}], ",", RowBox[
                   {"Momentum", "[", "q", "]"}]}], "]"}], "\[Rule]", "0"}], 
            ",", RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", 
                    "[", "p", "]"}], ",", RowBox[{"Momentum", "[", "p", 
                    "]"}]}], "]"}], "\[Rule]", "p2"}], ",", 
            RowBox[{RowBox[{"Pair", "[", RowBox[{RowBox[{"Momentum", "[", 
                    "p", "]"}], ",", RowBox[{"Momentum", "[", "q", "]"}]}], 
                "]"}], "\[Rule]", FractionBox[RowBox[{"pPrime2", "-", "p2"}], 
               "2"]}], ",", RowBox[{RowBox[{"Pair", "[", RowBox[
                 {RowBox[{"Momentum", "[", "q", "]"}], ",", RowBox[
                   {"Momentum", "[", "p", "]"}]}], "]"}], "\[Rule]", 
              FractionBox[RowBox[{"pPrime2", "-", "p2"}], "2"]}]}], "}"}]}], 
      ";", RowBox[{RowBox[{"expandParameterSP", "[", "expression_", "]"}], 
        ":=", RowBox[{"Expand", "[", RowBox[{"FCE", "[", 
            RowBox[{RowBox[{"ExpandScalarProduct", "[", RowBox[{"FCI", "[", 
                  "expression", "]"}], "]"}], "/.", "\[VeryThinSpace]", 
              "parameterKinematics"}], "]"}], "]"}]}], ";", 
      RowBox[{RowBox[{"simplexReduce", "[", "expression_", "]"}], ":=", 
        RowBox[{"Simplify", "[", RowBox[{"Together", "[", 
            RowBox[{RowBox[{"expandParameterSP", "[", "expression", "]"}], 
              "/.", "\[VeryThinSpace]", RowBox[{"z", "\[Rule]", 
                RowBox[{"1", "-", "x", "-", "y"}]}]}], "]"}], "]"}]}], 
      ";"}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"deltaH", "=", 
        RowBox[{RowBox[{RowBox[{"(", RowBox[{"x", "+", "y"}], ")"}], " ", 
            SuperscriptBox["mQ", "2"]}], "+", RowBox[{"z", " ", 
            SuperscriptBox["ms", "2"]}], "-", RowBox[{"x", " ", "z", " ", 
            "pPrime2"}], "-", RowBox[{"y", " ", "z", " ", "p2"}]}]}], ";", 
      RowBox[{"shiftH", "=", RowBox[{RowBox[{"x", " ", "q"}], "-", 
          RowBox[{"z", " ", "p"}]}]}], ";", 
      RowBox[{"weightedH", "=", RowBox[
         {RowBox[{"x", " ", RowBox[{"(", RowBox[{RowBox[{"SP", "[", 
                  RowBox[{RowBox[{"k", "+", "q"}], ",", RowBox[{"k", "+", 
                      "q"}]}], "]"}], "-", SuperscriptBox["mQ", "2"]}], 
              ")"}]}], "+", RowBox[{"y", " ", RowBox[
             {"(", RowBox[{RowBox[{"SP", "[", RowBox[{"k", ",", "k"}], "]"}], 
                "-", SuperscriptBox["mQ", "2"]}], ")"}]}], "+", 
          RowBox[{"z", " ", RowBox[{"(", RowBox[{RowBox[{"SP", "[", 
                  RowBox[{RowBox[{"k", "-", "p"}], ",", RowBox[{"k", "-", 
                      "p"}]}], "]"}], "-", SuperscriptBox["ms", "2"]}], 
              ")"}]}]}]}], ";", RowBox[{"heavyParameterResidual", "=", 
        RowBox[{"simplexReduce", "[", RowBox[{"weightedH", "-", 
            RowBox[{"(", RowBox[{RowBox[{"SP", "[", RowBox[{RowBox[{"k", "+", 
                      "shiftH"}], ",", RowBox[{"k", "+", "shiftH"}]}], "]"}], 
                "-", "deltaH"}], ")"}]}], "]"}]}], ";", 
      RowBox[{"Association", "[", RowBox[{RowBox[{"\"shift R_H\"", "\[Rule]", 
            "shiftH"}], ",", RowBox[{"\"Delta_H\"", "\[Rule]", "deltaH"}], 
          ",", RowBox[{"\"identity residual\"", "\[Rule]", 
            "heavyParameterResidual"}]}], "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"deltaS", "=", 
        RowBox[{RowBox[{"x", " ", SuperscriptBox["mQ", "2"]}], "+", 
          RowBox[{RowBox[{"(", RowBox[{"y", "+", "z"}], ")"}], " ", 
            SuperscriptBox["ms", "2"]}], "-", RowBox[{"x", " ", "y", " ", 
            "p2"}], "-", RowBox[{"x", " ", "z", " ", "pPrime2"}]}]}], ";", 
      RowBox[{"shiftS", "=", RowBox[{RowBox[{RowBox[{"-", "y"}], " ", "p"}], 
          "-", RowBox[{"z", " ", RowBox[{"(", RowBox[{"p", "+", "q"}], 
              ")"}]}]}]}], ";", RowBox[{"weightedS", "=", 
        RowBox[{RowBox[{"x", " ", RowBox[{"(", RowBox[{RowBox[{"SP", "[", 
                  RowBox[{"k", ",", "k"}], "]"}], "-", SuperscriptBox["mQ", 
                 "2"]}], ")"}]}], "+", RowBox[{"y", " ", 
            RowBox[{"(", RowBox[{RowBox[{"SP", "[", RowBox[{RowBox[{"k", "-", 
                      "p"}], ",", RowBox[{"k", "-", "p"}]}], "]"}], "-", 
                SuperscriptBox["ms", "2"]}], ")"}]}], "+", 
          RowBox[{"z", " ", RowBox[{"(", RowBox[{RowBox[{"SP", "[", 
                  RowBox[{RowBox[{"k", "-", "p", "-", "q"}], ",", RowBox[
                     {"k", "-", "p", "-", "q"}]}], "]"}], "-", SuperscriptBox[
                 "ms", "2"]}], ")"}]}]}]}], ";", 
      RowBox[{"strangeParameterResidual", "=", 
        RowBox[{"simplexReduce", "[", RowBox[{"weightedS", "-", 
            RowBox[{"(", RowBox[{RowBox[{"SP", "[", RowBox[{RowBox[{"k", "+", 
                      "shiftS"}], ",", RowBox[{"k", "+", "shiftS"}]}], "]"}], 
                "-", "deltaS"}], ")"}]}], "]"}]}], ";", 
      RowBox[{"Association", "[", RowBox[{RowBox[{"\"shift R_S\"", "\[Rule]", 
            "shiftS"}], ",", RowBox[{"\"Delta_S\"", "\[Rule]", "deltaS"}], 
          ",", RowBox[{"\"identity residual\"", "\[Rule]", 
            "strangeParameterResidual"}]}], "]"}]}]], "Input"], 
  Cell["The common identity is 1/(D1 D2 D3) = 2 Integral dx dy [x D1+y \
D2+(1-x-y)D3]^(-3), with 0<=x<=1 and 0<=y<=1-x.", "Text"], 
  Cell["9. Soft two-particle Fierz traces", "Section"], 
  Cell[BoxData[RowBox[
     {RowBox[{RowBox[{"traceForSoft", "[", RowBox[{"current_", ",", 
            "basis_"}], "]"}], ":=", RowBox[
         {RowBox[{"DiracSimplify", "[", RowBox[{RowBox[{"DiracTrace", "[", 
                RowBox[{RowBox[{"gammaP", "[", "]"}], ".", RowBox[
                   {"propNumerator", "[", RowBox[{"k", ",", "mQ"}], "]"}], 
                  ".", RowBox[{"current", "[", "mu", "]"}], ".", "basis"}], 
                "]"}], ",", RowBox[{"DiracSubstitute67", "\[Rule]", 
                "True"}]}], "]"}], "/.", "\[VeryThinSpace]", 
          "kinematicRules"}]}], ";", RowBox[{"softBasis", "=", 
        RowBox[{"{", RowBox[{RowBox[{"\"scalar\"", "\[Rule]", "1"}], ",", 
            RowBox[{"\"pseudoscalar\"", "\[Rule]", RowBox[{"\[ImaginaryI]", 
                " ", RowBox[{"GA", "[", "5", "]"}]}]}], ",", 
            RowBox[{"\"vector\"", "\[Rule]", RowBox[{"GA", "[", "rho", 
                "]"}]}], ",", RowBox[{"\"axial\"", "\[Rule]", 
              RowBox[{RowBox[{"GA", "[", "rho", "]"}], ".", RowBox[
                 {"GA", "[", "5", "]"}]}]}], ",", RowBox[{"\"tensor\"", 
              "\[Rule]", RowBox[{"DiracSigma", "[", RowBox[
                 {RowBox[{"GA", "[", "rho", "]"}], ",", RowBox[{"GA", "[", 
                    "lambda", "]"}]}], "]"}]}]}], "}"}]}], ";", 
      RowBox[{"softTracesA", "=", RowBox[{"AssociationThread", "[", 
          RowBox[{RowBox[{"softBasis", "\[LeftDoubleBracket]", 
              RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
            RowBox[{RowBox[{"(", RowBox[{RowBox[{"traceForSoft", "[", 
                    RowBox[{"gammaA", ",", "#1"}], "]"}], "&"}], ")"}], "/@", 
              RowBox[{"softBasis", "\[LeftDoubleBracket]", RowBox[
                 {"All", ",", "2"}], "\[RightDoubleBracket]"}]}]}], "]"}]}], 
      ";", RowBox[{"softTracesB", "=", RowBox[{"AssociationThread", "[", 
          RowBox[{RowBox[{"softBasis", "\[LeftDoubleBracket]", 
              RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
            RowBox[{RowBox[{"(", RowBox[{RowBox[{"traceForSoft", "[", 
                    RowBox[{"gammaB", ",", "#1"}], "]"}], "&"}], ")"}], "/@", 
              RowBox[{"softBasis", "\[LeftDoubleBracket]", RowBox[
                 {"All", ",", "2"}], "\[RightDoubleBracket]"}]}]}], "]"}]}], 
      ";", RowBox[{"{", RowBox[{"softTracesA", ",", "softTracesB"}], 
        "}"}]}]], "Input"], Cell["10. Legacy-routing diagnostic", "Section"], 
  Cell["The old strange-line momentum k-p+q makes the initial-current \
momentum p-q. It therefore does not satisfy the Rohrwild correlator routing \
pPrime=p+q.", "Text"], 
  Cell[BoxData[RowBox[{RowBox[{"legacyStrangeInitialMomentum", "=", 
        RowBox[{"k", "-", RowBox[{"(", RowBox[{"k", "-", "p", "+", "q"}], 
            ")"}]}]}], ";", RowBox[{"Association", "[", 
        RowBox[{RowBox[{"\"legacy actual\"", "\[Rule]", 
            "legacyStrangeInitialMomentum"}], ",", 
          RowBox[{"\"required\"", "\[Rule]", RowBox[{"p", "+", "q"}]}], ",", 
          RowBox[{"\"difference\"", "\[Rule]", RowBox[{"Simplify", "[", 
              RowBox[{"legacyStrangeInitialMomentum", "-", RowBox[
                 {"(", RowBox[{"p", "+", "q"}], ")"}]}], "]"}]}]}], "]"}]}]], 
   "Input"], Cell["11. Physical-state projection and Colangelo limit", 
   "Section"], Cell["The current rotation acts linearly on the E1 invariant \
amplitudes. Colangelo, De Fazio, and Ozpineci use the axial current J_A only. \
With J_low=Sin[theta] J_A+Cos[theta] J_B, their calculation is the theta=Pi/2 \
limit. Residue factors are retained explicitly.", "Text"], 
  Cell[BoxData[RowBox[{RowBox[{RowBox[{"stateRotation", "[", "angle_", "]"}], 
        ":=", RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"Sin", "[", 
                  "angle", "]"}], ",", RowBox[{"Cos", "[", "angle", "]"}]}], 
              "}"}], ",", RowBox[{"{", RowBox[{RowBox[{"Cos", "[", "angle", 
                  "]"}], ",", RowBox[{"-", RowBox[{"Sin", "[", "angle", 
                    "]"}]}]}], "}"}]}], "}"}]}], ";", 
      RowBox[{"rTheta", "=", RowBox[{"stateRotation", "[", "theta", "]"}]}], 
      ";", RowBox[{"stateRotationResidual", "=", 
        RowBox[{"FullSimplify", "[", RowBox[
           {RowBox[{RowBox[{TemplateBox[{"rTheta"}, "Transpose", 
                 SyntaxForm -> SuperscriptBox], ".", "rTheta"}], "-", 
              RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ",", 
            RowBox[{"Assumptions", "\[Rule]", RowBox[{"theta", "\[Element]", 
                TemplateBox[{}, "Reals"]}]}]}], "]"}]}], ";", 
      RowBox[{"transitionPhysical", "=", RowBox[{"Expand", "[", 
          RowBox[{"rTheta", ".", RowBox[{"{", RowBox[{"tA", ",", "tB"}], 
              "}"}]}], "]"}]}], ";", RowBox[{"pureAxialTransitionResidual", 
        "=", RowBox[{"Simplify", "[", RowBox[
           {RowBox[{"(", RowBox[{"transitionPhysical", "/.", 
                "\[VeryThinSpace]", RowBox[{"theta", "\[Rule]", FractionBox[
                   "\[Pi]", "2"]}]}], ")"}], "-", 
            RowBox[{"{", RowBox[{"tA", ",", RowBox[{"-", "tB"}]}], "}"}]}], 
          "]"}]}], ";", RowBox[{"Association", "[", 
        RowBox[{RowBox[{"\"R(theta)\"", "\[Rule]", "rTheta"}], ",", 
          RowBox[{"\"R^T R - 1\"", "\[Rule]", "stateRotationResidual"}], ",", 
          RowBox[{"\"{T_low,T_high}\"", "\[Rule]", "transitionPhysical"}], 
          ",", RowBox[{"\"pure-A residual\"", "\[Rule]", 
            "pureAxialTransitionResidual"}]}], "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"g1", "=", FractionBox[
         RowBox[{RowBox[{RowBox[{"Sin", "[", "theta", "]"}], " ", "fA", " ", 
             "gA"}], "+", RowBox[{RowBox[{"Cos", "[", "theta", "]"}], " ", 
             "fB", " ", "gB"}]}], "f1"]}], ";", 
      RowBox[{"g2", "=", FractionBox[RowBox[
          {RowBox[{RowBox[{"Cos", "[", "theta", "]"}], " ", "fA", " ", 
             "gA"}], "-", RowBox[{RowBox[{"Sin", "[", "theta", "]"}], " ", 
             "fB", " ", "gB"}]}], "f2"]}], ";", 
      RowBox[{"pureAxialCouplingResidual", "=", 
        RowBox[{"Simplify", "[", RowBox[{RowBox[{"(", RowBox[{"g1", "/.", 
                "\[VeryThinSpace]", RowBox[{"{", RowBox[{RowBox[{"theta", 
                      "\[Rule]", FractionBox["\[Pi]", "2"]}], ",", 
                    RowBox[{"f1", "\[Rule]", "fA"}]}], "}"}]}], ")"}], "-", 
            "gA"}], "]"}]}], ";", RowBox[{"gColangeloFromOPE", "=", 
        FractionBox[RowBox[{RowBox[{"Exp", "[", RowBox[{FractionBox[
                SuperscriptBox["m1", "2"], "borel1"], "+", FractionBox[
                SuperscriptBox["mP", "2"], "borel2"]}], "]"}], " ", 
           RowBox[{"(", RowBox[{"mQ", "+", "ms"}], ")"}], " ", "tA"}], 
         RowBox[{"m1", " ", "fA", " ", SuperscriptBox["mP", "2"], " ", 
           "fP"}]]}], ";", RowBox[{"gLowFromOPE", "=", 
        FractionBox[RowBox[{RowBox[{"Exp", "[", RowBox[{FractionBox[
                SuperscriptBox["m1", "2"], "borel1"], "+", FractionBox[
                SuperscriptBox["mP", "2"], "borel2"]}], "]"}], " ", 
           RowBox[{"(", RowBox[{"mQ", "+", "ms"}], ")"}], " ", 
           RowBox[{"(", RowBox[{RowBox[{RowBox[{"Sin", "[", "theta", "]"}], 
                 " ", "tA"}], "+", RowBox[{RowBox[{"Cos", "[", "theta", 
                   "]"}], " ", "tB"}]}], ")"}]}], 
         RowBox[{"m1", " ", "f1", " ", SuperscriptBox["mP", "2"], " ", 
           "fP"}]]}], ";", RowBox[{"colangeloFormulaResidual", "=", 
        RowBox[{"Simplify", "[", RowBox[{RowBox[{"(", RowBox[{"gLowFromOPE", 
                "/.", "\[VeryThinSpace]", RowBox[{"{", RowBox[
                   {RowBox[{"theta", "\[Rule]", FractionBox["\[Pi]", "2"]}], 
                    ",", RowBox[{"f1", "\[Rule]", "fA"}]}], "}"}]}], ")"}], 
            "-", "gColangeloFromOPE"}], "]"}]}], ";", 
      RowBox[{"Association", "[", RowBox[{RowBox[{"\"G_low\"", "\[Rule]", 
            "g1"}], ",", RowBox[{"\"G_high\"", "\[Rule]", "g2"}], ",", 
          RowBox[{"\"pure-A coupling residual\"", "\[Rule]", 
            "pureAxialCouplingResidual"}], ",", 
          RowBox[{"\"Colangelo OPE formula residual\"", "\[Rule]", 
            "colangeloFormulaResidual"}]}], "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"correlationBasis", "=", 
        RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"piAA", ",", "piAB"}], 
              "}"}], ",", RowBox[{"{", RowBox[{"piAB", ",", "piBB"}], 
              "}"}]}], "}"}]}], ";", RowBox[{"correlationPhysical", "=", 
        RowBox[{"Expand", "[", RowBox[{"rTheta", ".", "correlationBasis", 
            ".", TemplateBox[{"rTheta"}, "Transpose", SyntaxForm -> 
              SuperscriptBox]}], "]"}]}], ";", 
      RowBox[{"expectedCorrelationPhysical", "=", 
        RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[
                 {RowBox[{SuperscriptBox[RowBox[{"Sin", "[", "theta", "]"}], 
                     "2"], " ", "piAA"}], "+", RowBox[{SuperscriptBox[
                     RowBox[{"Cos", "[", "theta", "]"}], "2"], " ", "piBB"}], 
                  "+", RowBox[{"2", " ", RowBox[{"Sin", "[", "theta", "]"}], 
                    " ", RowBox[{"Cos", "[", "theta", "]"}], " ", "piAB"}]}], 
                ",", RowBox[{RowBox[{RowBox[{"Sin", "[", "theta", "]"}], " ", 
                    RowBox[{"Cos", "[", "theta", "]"}], " ", RowBox[
                     {"(", RowBox[{"piAA", "-", "piBB"}], ")"}]}], "+", 
                  RowBox[{RowBox[{"(", RowBox[{SuperscriptBox[RowBox[{"Cos", 
                          "[", "theta", "]"}], "2"], "-", SuperscriptBox[
                         RowBox[{"Sin", "[", "theta", "]"}], "2"]}], ")"}], 
                    " ", "piAB"}]}]}], "}"}], ",", 
            RowBox[{"{", RowBox[{RowBox[{RowBox[{RowBox[{"Sin", "[", "theta", 
                      "]"}], " ", RowBox[{"Cos", "[", "theta", "]"}], " ", 
                    RowBox[{"(", RowBox[{"piAA", "-", "piBB"}], ")"}]}], "+", 
                  RowBox[{RowBox[{"(", RowBox[{SuperscriptBox[RowBox[{"Cos", 
                          "[", "theta", "]"}], "2"], "-", SuperscriptBox[
                         RowBox[{"Sin", "[", "theta", "]"}], "2"]}], ")"}], 
                    " ", "piAB"}]}], ",", RowBox[{RowBox[{SuperscriptBox[
                     RowBox[{"Cos", "[", "theta", "]"}], "2"], " ", "piAA"}], 
                  "+", RowBox[{SuperscriptBox[RowBox[{"Sin", "[", "theta", 
                       "]"}], "2"], " ", "piBB"}], "-", RowBox[{"2", " ", 
                    RowBox[{"Sin", "[", "theta", "]"}], " ", RowBox[
                     {"Cos", "[", "theta", "]"}], " ", "piAB"}]}]}], "}"}]}], 
          "}"}]}], ";", RowBox[{"correlationRotationResidual", "=", 
        RowBox[{"FullSimplify", "[", RowBox[{RowBox[{"correlationPhysical", 
              "-", "expectedCorrelationPhysical"}], ",", 
            RowBox[{"Assumptions", "\[Rule]", RowBox[{"theta", "\[Element]", 
                TemplateBox[{}, "Reals"]}]}]}], "]"}]}], ";", 
      RowBox[{"f1Squared", "=", FractionBox[
         RowBox[{RowBox[{"Exp", "[", FractionBox[SuperscriptBox["m1", "2"], 
              "borelTwoPoint"], "]"}], " ", RowBox[
            {"expectedCorrelationPhysical", "\[LeftDoubleBracket]", 
             RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]}], 
         SuperscriptBox["m1", "2"]]}], ";", 
      RowBox[{"f2Squared", "=", FractionBox[
         RowBox[{RowBox[{"Exp", "[", FractionBox[SuperscriptBox["m2", "2"], 
              "borelTwoPoint"], "]"}], " ", RowBox[
            {"expectedCorrelationPhysical", "\[LeftDoubleBracket]", 
             RowBox[{"2", ",", "2"}], "\[RightDoubleBracket]"}]}], 
         SuperscriptBox["m2", "2"]]}], ";", 
      RowBox[{"pureAxialDecayConstantResidual", "=", 
        RowBox[{"Simplify", "[", RowBox[{RowBox[{"(", RowBox[{"f1Squared", 
                "/.", "\[VeryThinSpace]", RowBox[{"theta", "\[Rule]", 
                  FractionBox["\[Pi]", "2"]}]}], ")"}], "-", 
            FractionBox[RowBox[{RowBox[{"Exp", "[", FractionBox[
                  SuperscriptBox["m1", "2"], "borelTwoPoint"], "]"}], " ", 
               "piAA"}], SuperscriptBox["m1", "2"]]}], "]"}]}], ";", 
      RowBox[{"Association", "[", RowBox[{RowBox[{"\"Pi physical\"", 
            "\[Rule]", "correlationPhysical"}], ",", 
          RowBox[{"\"f_low^2\"", "\[Rule]", "f1Squared"}], ",", 
          RowBox[{"\"f_high^2\"", "\[Rule]", "f2Squared"}], ",", 
          RowBox[{"\"rotation residual\"", "\[Rule]", 
            "correlationRotationResidual"}], ",", 
          RowBox[{"\"pure-A f residual\"", "\[Rule]", 
            "pureAxialDecayConstantResidual"}]}], "]"}]}]], "Input"], 
  Cell[BoxData[RowBox[{RowBox[{"twoPointOPE11", "=", 
        RowBox[{TemplateBox[{RowBox[{RowBox[{"Exp", "[", RowBox[
                 {"-", FractionBox["s", "borelTwoPoint"]}], "]"}], " ", 
              RowBox[{"(", RowBox[{RowBox[{SuperscriptBox[RowBox[{"Sin", "[", 
                       "theta", "]"}], "2"], " ", RowBox[{"piAAPert", "[", 
                      "s", "]"}]}], "+", RowBox[{SuperscriptBox[RowBox[
                      {"Cos", "[", "theta", "]"}], "2"], " ", RowBox[
                     {"piBBPert", "[", "s", "]"}]}], "+", RowBox[{"2", " ", 
