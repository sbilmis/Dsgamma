                    "\[Rule]", RowBox[{"{", RowBox[{"0.203`", ",", "0.121`", 
                        ",", "0.291`"}], "}"}]}]}], "]"}]}]}], "]"}]}], ";", 
      RowBox[{"Association", "[", RowBox[{RowBox[{"\"f1^2 overlap model\"", 
