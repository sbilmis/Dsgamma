                 "}"}]}], "]"}] & )]}], ";", 
      RowBox[{RowBox[{"IF1", "[", "uval_", "]"}], ":=", 
        RowBox[{TemplateBox[{TemplateBox[{RowBox[{"F1DA", "[", 
                RowBox[{RowBox[{"uval", "-", RowBox[{RowBox[{"(", RowBox[
                         {"1", "-", "v"}], ")"}], " ", "alphaG"}]}], ",", 
                  RowBox[{"1", "-", "uval", "-", RowBox[{"v", " ", 
                      "alphaG"}]}], ",", "alphaG"}], "]"}], "alphaG", "0", 
              FractionBox["uval", RowBox[{"1", "-", "v"}]]}, 
             "InactiveIntegrate", DisplayFunction -> (RowBox[
                {SubsuperscriptBox[StyleBox["\[Integral]", "Inactive"], #3, 
                  #4], RowBox[{#1, RowBox[{StyleBox["\[DifferentialD]", 
                      "Inactive"], #2}]}]}] & ), InterpretationFunction -> 
              (RowBox[{RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
                 RowBox[{#1, ",", RowBox[{"{", RowBox[{#2, ",", #3, ",", 
                       #4}], "}"}]}], "]"}] & )], "v", "0", 
            RowBox[{"1", "-", "uval"}]}, "InactiveIntegrate", 
           DisplayFunction -> (RowBox[{SubsuperscriptBox[StyleBox[
