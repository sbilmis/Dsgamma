                   {"zeroResidualQ", "/@", RowBox[{"Values", "[", 
                      "checkResiduals", "]"}]}]}], ",", "\"PASS\"", ",", 
                "\"FAIL\""}], "]"}]}]}], "]"}]}]], "Input"], 
  Cell["For a clean batch regression run, execute \
scripts/mathematica_current_wick_trace_audit.wl, \
scripts/mathematica_correlator_routing_audit.wl, and \
scripts/mathematica_hard_loop_parameterization.wl. The state projection has \
its own scripts/mathematica_state_mixing_projection.wl audit. The Bs channel \
uses the same symbolic expressions with mQ -> mb and the appropriate \
heavy-quark charge.", "Text"]}, WindowTitle -> 
  "Ds/Bs gamma symbolic derivation", Saveable -> True, 
