                          RowBox[{"shat", ",", SuperscriptBox["mj", "2"], 
                          ",", SuperscriptBox["mi", "2"]}], "]"}]]}], 
                      RowBox[{"shat", "-", SuperscriptBox["mj", "2"], "+", 
                        SuperscriptBox["mi", "2"], "+", SqrtBox[RowBox[
                          {"kallenLambda", "[", RowBox[{"shat", ",", 
                          SuperscriptBox["mj", "2"], ",", SuperscriptBox[
                          "mi", "2"]}], "]"}]]}]], "]"}]}], "+", FractionBox[
                  RowBox[{RowBox[{"(", RowBox[{"mj", "-", "mi"}], ")"}], " ", 
                    RowBox[{"(", RowBox[{SuperscriptBox["mj", "2"], "-", 
                        SuperscriptBox["mi", "2"], "-", "shat"}], ")"}], " ", 
                    SqrtBox[RowBox[{"kallenLambda", "[", RowBox[{"shat", ",", 
                         SuperscriptBox["mj", "2"], ",", SuperscriptBox["mi", 
                          "2"]}], "]"}]]}], SuperscriptBox["shat", "2"]]}], 
               ")"}]}], RowBox[{"8", " ", SuperscriptBox["\[Pi]", 
              "2"]}]]}]}], ";", RowBox[{RowBox[{"rhoA", "[", "shat_", "]"}], 
        ":=", RowBox[{RowBox[{"rhoPiece", "[", RowBox[{"shat", ",", "ms", 
              ",", "mQ", ",", "eS"}], "]"}], "-", 
          RowBox[{"rhoPiece", "[", RowBox[{"shat", ",", "mQ", ",", "ms", ",", 
              "eQ"}], "]"}]}]}], ";", 
      RowBox[{RowBox[{"HbarGamma", "[", "uval_", "]"}], ":=", 
        TemplateBox[{RowBox[{RowBox[{"(", RowBox[{"uval", "-", "w"}], ")"}], 
            " ", RowBox[{"hGamma", "[", "w", "]"}]}], "w", "0", "uval"}, 
         "InactiveIntegrate", DisplayFunction -> 
          (RowBox[{SubsuperscriptBox[StyleBox["\[Integral]", "Inactive"], #3, 
              #4], RowBox[{#1, RowBox[{StyleBox["\[DifferentialD]", 
                  "Inactive"], #2}]}]}] & ), InterpretationFunction -> 
          (RowBox[{RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
             RowBox[{#1, ",", RowBox[{"{", RowBox[{#2, ",", #3, ",", #4}], 
                 "}"}]}], "]"}] & )]}], ";", 
      RowBox[{RowBox[{"PsiV", "[", "uval_", "]"}], ":=", 
        TemplateBox[{RowBox[{"psiV", "[", "w", "]"}], "w", "0", "uval"}, 
         "InactiveIntegrate", DisplayFunction -> 
          (RowBox[{SubsuperscriptBox[StyleBox["\[Integral]", "Inactive"], #3, 
              #4], RowBox[{#1, RowBox[{StyleBox["\[DifferentialD]", 
