                     {"Cos", "[", "theta", "]"}], " ", RowBox[{"piABPert", 
                      "[", "s", "]"}]}]}], ")"}]}], "s", "sThreshold", "s0"}, 
           "InactiveIntegrate", DisplayFunction -> 
            (RowBox[{SubsuperscriptBox[StyleBox["\[Integral]", "Inactive"], 
                #3, #4], RowBox[{#1, RowBox[{StyleBox["\[DifferentialD]", 
                    "Inactive"], #2}]}]}] & ), InterpretationFunction -> 
            (RowBox[{RowBox[{"Inactive", "[", "Integrate", "]"}], "[", RowBox[
                {#1, ",", RowBox[{"{", RowBox[{#2, ",", #3, ",", #4}], 
                   "}"}]}], "]"}] & )], "+", 
          RowBox[{SuperscriptBox[RowBox[{"Sin", "[", "theta", "]"}], "2"], 
            " ", "piAACond"}], "+", RowBox[{SuperscriptBox[
             RowBox[{"Cos", "[", "theta", "]"}], "2"], " ", "piBBCond"}], 
          "+", RowBox[{"2", " ", RowBox[{"Sin", "[", "theta", "]"}], " ", 
            RowBox[{"Cos", "[", "theta", "]"}], " ", "piABCond"}]}]}], ";", 
      RowBox[{"twoPointOPE22", "=", RowBox[
         {TemplateBox[{RowBox[{RowBox[{"Exp", "[", RowBox[{"-", FractionBox[
                   "s", "borelTwoPoint"]}], "]"}], " ", RowBox[{"(", 
                RowBox[{RowBox[{SuperscriptBox[RowBox[{"Cos", "[", "theta", 
                       "]"}], "2"], " ", RowBox[{"piAAPert", "[", "s", 
                      "]"}]}], "+", RowBox[{SuperscriptBox[RowBox[{"Sin", 
                       "[", "theta", "]"}], "2"], " ", RowBox[{"piBBPert", 
                      "[", "s", "]"}]}], "-", RowBox[{"2", " ", RowBox[
                     {"Sin", "[", "theta", "]"}], " ", RowBox[{"Cos", "[", 
                      "theta", "]"}], " ", RowBox[{"piABPert", "[", "s", 
                      "]"}]}]}], ")"}]}], "s", "sThreshold", "s0"}, 
           "InactiveIntegrate", DisplayFunction -> 
            (RowBox[{SubsuperscriptBox[StyleBox["\[Integral]", "Inactive"], 
                #3, #4], RowBox[{#1, RowBox[{StyleBox["\[DifferentialD]", 
                    "Inactive"], #2}]}]}] & ), InterpretationFunction -> 
            (RowBox[{RowBox[{"Inactive", "[", "Integrate", "]"}], "[", RowBox[
                {#1, ",", RowBox[{"{", RowBox[{#2, ",", #3, ",", #4}], 
                   "}"}]}], "]"}] & )], "+", 
          RowBox[{SuperscriptBox[RowBox[{"Cos", "[", "theta", "]"}], "2"], 
            " ", "piAACond"}], "+", RowBox[{SuperscriptBox[
             RowBox[{"Sin", "[", "theta", "]"}], "2"], " ", "piBBCond"}], 
          "-", RowBox[{"2", " ", RowBox[{"Sin", "[", "theta", "]"}], " ", 
            RowBox[{"Cos", "[", "theta", "]"}], " ", "piABCond"}]}]}], ";", 
      RowBox[{"Association", "[", RowBox[
         {RowBox[{"\"Pi_11 OPE in basis blocks\"", "\[Rule]", 
            "twoPointOPE11"}], ",", RowBox[{"\"Pi_22 OPE in basis blocks\"", 
            "\[Rule]", "twoPointOPE22"}], ",", 
          RowBox[{"\"direct f1^2 if all blocks are known\"", "\[Rule]", 
